{% extends "base.njk" %}

{% block title %}Submit Vouch | Reputation Entry{% endblock %}

{% block content %}
<section id="vouch-header">
    <h1 class="gradient-text">Submit Reputation</h1>
    <p>Document your experience with another network participant. Please be honest and detailed.</p>
</section>

<div class="vouch-form-container slide-in">
    {% if success %}
    <div class="alert success-alert">
        <i class="fas fa-check-circle"></i>
        <span>Reputation documented successfully! The network has been updated.</span>
    </div>
    {% endif %}
    
    {% if error %}
    <div class="alert error-alert">
        <i class="fas fa-exclamation-circle"></i>
        <span>{{ error }}</span>
    </div>
    {% endif %}

    <form action="/vouch" method="POST" class="vouch-form">
        <div class="form-row">
            <div class="form-group">
                <label>Receiver (User ID or Tag)</label>
                <input type="text" name="receiver_query" placeholder="e.g. 1383706658315960330 or User#0001" required>
            </div>
            
            <div class="form-group">
                <label>Target Server</label>
                <select name="guild_id" required>
                    {% for g in userGuilds %}
                    <option value="{{ g.id }}">{{ g.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Experience Rating</label>
            <div class="star-rating">
                <input type="radio" name="rating" value="5" id="r5" checked><label for="r5">★</label>
                <input type="radio" name="rating" value="4" id="r4"><label for="r4">★</label>
                <input type="radio" name="rating" value="3" id="r3"><label for="r3">★</label>
                <input type="radio" name="rating" value="2" id="r2"><label for="r2">★</label>
                <input type="radio" name="rating" value="1" id="r1"><label for="r1">★</label>
            </div>
        </div>

        <div class="form-group">
            <label>Comment / Feedback</label>
            <textarea name="comment" rows="5" placeholder="Describe your transaction or interaction in detail..."></textarea>
            <p class="help-text">Detailed comments help build greater trust within the community.</p>
        </div>

        <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i>
            Commit to Blockchain
        </button>
    </form>
</div>

<style>
    .vouch-form-container {
        margin-top: 3rem;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 3rem;
        max-width: 800px;
    }

    .alert {
        padding: 1.2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 600;
    }

    .success-alert { background: rgba(87, 242, 135, 0.1); color: #57f287; border: 1px solid rgba(87, 242, 135, 0.2); }
    .error-alert { background: rgba(255, 71, 133, 0.1); color: #ff4785; border: 1px solid rgba(255, 71, 133, 0.2); }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .vouch-form textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        padding: 1.2rem;
        border-radius: 12px;
        color: white;
        font-family: inherit;
        resize: vertical;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .star-rating input { display: none; }
    .star-rating label {
        font-size: 2.5rem;
        color: var(--border);
        cursor: pointer;
        transition: 0.2s;
    }

    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color: var(--gold);
    }

    .submit-btn {
        margin-top: 2rem;
        width: 100%;
        background: var(--primary);
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 14px;
        font-weight: 800;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .submit-btn:hover { filter: brightness(1.2); transform: scale(1.01); }
</style>
{% endblock %}
