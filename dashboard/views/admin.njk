{% extends "base.njk" %}

{% block title %}Server Administration | Control Panel{% endblock %}

{% block content %}
<section id="admin-header" class="fade-in">
    <h1 class="gradient-text">Guild Management</h1>
    <p>Configure the Vouch Bot specifically for <strong>{{ guild.name }}</strong>.</p>
</section>

<div class="admin-grid slide-in" style="animation-delay: 0.1s; margin-top: 3rem; display: grid; grid-template-columns: 1fr 320px; gap: 2rem;">
    <form action="/admin/update" method="POST" class="panel">
        <input type="hidden" name="guild_id" value="{{ guild.id }}">
        
        <div class="panel-section" style="margin-bottom: 3rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 2rem; color: var(--primary); display: flex; align-items: center; gap: 0.8rem;">
                <i class="fas fa-hashtag"></i> Infrastructure
            </h3>
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.85rem; text-transform: uppercase; color: var(--text-secondary);">Vouch Channel</label>
                <select name="vouch_channel_id" style="width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); padding: 1rem; border-radius: 12px; color: white; font-family: inherit; font-size: 1rem; outline: none;">
                    <option value="">-- No Channel Set --</option>
                    {% for channel in channels %}
                    <option value="{{ channel.id }}" {% if settings.vouch_channel_id == channel.id %}selected{% endif %}>#{{ channel.name }}</option>
                    {% endfor %}
                </select>
                <p class="help-text" style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem; opacity: 0.7;">Where users can submit vouches via command.</p>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.85rem; text-transform: uppercase; color: var(--text-secondary);">Log Channel</label>
                <select name="log_channel_id" style="width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); padding: 1rem; border-radius: 12px; color: white; font-family: inherit; font-size: 1rem; outline: none;">
                    <option value="">-- No Channel Set --</option>
                    {% for channel in channels %}
                    <option value="{{ channel.id }}" {% if settings.log_channel_id == channel.id %}selected{% endif %}>#{{ channel.name }}</option>
                    {% endfor %}
                </select>
                <p class="help-text" style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem; opacity: 0.7;">Internal log of all vouch activities.</p>
            </div>
        </div>

        <div class="panel-section" style="margin-bottom: 3rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 2rem; color: var(--secondary); display: flex; align-items: center; gap: 0.8rem;">
                <i class="fas fa-stopwatch"></i> Security Policies
            </h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.85rem; text-transform: uppercase; color: var(--text-secondary);">Vouch Cooldown (Hours)</label>
                    <input type="number" name="vouch_cooldown_hours" value="{{ settings.vouch_cooldown_hours }}" min="0" style="width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); padding: 1rem; border-radius: 12px; color: white; font-family: inherit; font-size: 1rem; outline: none;">
                </div>
                
                <div class="form-group">
                    <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.85rem; text-transform: uppercase; color: var(--text-secondary);">Min Account Age (Days)</label>
                    <input type="number" name="min_account_age_days" value="{{ settings.min_account_age_days }}" min="0" style="width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); padding: 1rem; border-radius: 12px; color: white; font-family: inherit; font-size: 1rem; outline: none;">
                </div>
            </div>

            <div class="checkbox-group" style="display: flex; align-items: center; gap: 0.8rem; margin-top: 1.5rem; background: rgba(255,255,255,0.02); padding: 1rem; border-radius: 12px; border: 1px solid var(--border);">
                <input type="checkbox" name="require_comment" id="req-cmt" {% if settings.require_comment %}checked{% endif %} style="width: 18px; height: 18px; cursor: pointer;">
                <label for="req-cmt" style="color: white; font-weight: 600; cursor: pointer; font-size: 0.95rem;">Require comment for valid vouch</label>
            </div>
        </div>

        <button type="submit" class="btn-primary" style="width: 100%; padding: 1.2rem; font-size: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.8rem;">
            <i class="fas fa-save"></i> Save Configuration
        </button>
    </form>

    <div class="status-panel panel" style="height: fit-content;">
        <div class="panel-header" style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
            <h3>System Status</h3>
            <span class="live-indicator">OPERATIONAL</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="status-item" style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                <span style="color: var(--text-secondary); font-weight: 600;">Engine Version</span>
                <span style="color: white; font-weight: 800;">v2.1.0-Stable</span>
            </div>
            <div class="status-item" style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                <span style="color: var(--text-secondary); font-weight: 600;">Database Sync</span>
                <span style="color: var(--secondary); font-weight: 800;">Active</span>
            </div>
            <div class="status-item" style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                <span style="color: var(--text-secondary); font-weight: 600;">User Scope</span>
                <span style="color: white; font-weight: 800;">{{ guild.memberCount }} members</span>
            </div>
        </div>
        
        <div class="quick-tips" style="margin-top: 2.5rem; background: var(--primary-glow); padding: 1.2rem; border-radius: 16px; border: 1px solid var(--border);">
            <h4 style="font-size: 0.85rem; margin-bottom: 0.5rem; color: var(--primary); text-transform: uppercase; font-weight: 800;">
                <i class="fas fa-lightbulb"></i> Optimization Tip
            </h4>
            <p style="font-size: 0.8rem; color: white; opacity: 0.8; line-height: 1.5;">Setting a <strong>Log Channel</strong> is highly recommended for auditing reputation shifts and catching fraud early.</p>
        </div>
    </div>
</div>
{% endblock %}
